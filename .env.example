# ── Server ────────────────────────────────────────────────────────────────────
# Port the Ktor server listens on. Railway injects PORT automatically.
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# JDBC connection URL. Must use the jdbc:postgresql:// scheme (not postgresql://).
# On Railway: set this to your PostgreSQL plugin's JDBC URL, e.g.:
#   jdbc:postgresql://<PGHOST>:<PGPORT>/<PGDATABASE>
DATABASE_URL=jdbc:postgresql://localhost:5432/messos_db

# Database credentials — must match the PostgreSQL user/password.
DATABASE_USERNAME=messos
DATABASE_PASSWORD=change-me-in-production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens. Must be at least 32 characters.
# Generate a strong secret: openssl rand -base64 48
# Example (do NOT use this value in production):
#   JWT_SECRET=6G8kP2mNvQrXsYzA3bCdEfHiJkLmOpRsTuVwYzAbCdEfGhIjKlMn==
JWT_SECRET=replace-with-a-random-256-bit-base64-encoded-secret

# How many days a JWT token is valid before the user must log in again.
JWT_EXPIRY_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
# Root log level. One of: TRACE, DEBUG, INFO, WARN, ERROR.
# Use DEBUG locally for verbose output; keep INFO or WARN in production.
LOG_LEVEL=INFO
